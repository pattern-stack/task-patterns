{
  "name": "task-pattern",
  "version": "1.0.0",
  "description": "Task management patterns for AI-assisted development (pattern-stack)",
  "main": "dist/index.js",
  "bin": {
    "task-pattern": "./bin/tp.js",
    "tp": "./bin/tp.js",
    "pattern": "./bin/tp.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "cli": "tsx src/organisms/cli/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=src/__tests__/(atoms|features|molecules)",
    "test:integration": "jest --testPathPattern=src/__tests__/organisms",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run test"
  },
  "keywords": [
    "linear",
    "graphql",
    "api",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@linear/sdk": "^28.0.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "ora": "^8.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "tp": {
    "teamFilter": [
      "TASK"
    ],
    "workspaceId": "optional_workspace_id"
  }
}