{
  "name": "@pattern-stack/task-patterns",
  "version": "0.1.0",
  "description": "Lightning-fast task management for AI-human collaborative development",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tp": "./bin/tp.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "prepublishOnly": "npm run verify && npm run build",
    "postpublish": "echo 'Successfully published @dugsnodes/task-patterns'",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "cli": "tsx src/organisms/cli/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=src/__tests__/(atoms|features|molecules)",
    "test:integration": "jest --testPathPattern=src/__tests__/organisms",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DougsHub/task-patterns.git"
  },
  "bugs": {
    "url": "https://github.com/DougsHub/task-patterns/issues"
  },
  "homepage": "https://github.com/DougsHub/task-patterns#readme",
  "keywords": [
    "task-management",
    "linear",
    "cli",
    "productivity",
    "ai-collaboration",
    "graphql",
    "api"
  ],
  "author": "Dug McFarlane <dug.mcfarlane@icloud.com>",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "dependencies": {
    "@linear/sdk": "^28.0.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "ora": "^8.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}